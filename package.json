{
  "name": "@xtacinema/contracts",
  "version": "1.0.0",
  "description": "Protobuf definitions and generated TypeScript types",
  "scripts": {
    "generate": "protoc -I ./proto ./proto/*.proto --ts_proto_out=./gen --ts_proto_opt=nestJs=true,package=omit"
  },
  "files": [
    "proto",
    "gen"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xtacinema/contracts.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@nestjs/microservices": "^11.1.14",
    "rxjs": "^7.8.2",
    "ts-proto": "^2.11.4"
  }
}